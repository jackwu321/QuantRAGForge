# LLM Provider Configuration
# Copy this to .env or export these variables in your shell.
# Any OpenAI-compatible API provider is supported.

# --- Option 1: Zhipu GLM (default) ---
# LLM_API_KEY=your-zhipu-api-key
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4.7
# LLM_EMBEDDING_MODEL=embedding-3

# --- Option 2: DeepSeek ---
# LLM_API_KEY=your-deepseek-api-key
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# LLM_EMBEDDING_MODEL=deepseek-embedding

# --- Option 3: Moonshot (Kimi) ---
# LLM_API_KEY=your-moonshot-api-key
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-8k

# --- Option 4: Qwen (Tongyi) ---
# LLM_API_KEY=your-dashscope-api-key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# --- Option 5: OpenAI ---
# LLM_API_KEY=your-openai-api-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_EMBEDDING_MODEL=text-embedding-3-small

# --- Option 6: Local (Ollama, vLLM, etc.) ---
# LLM_API_KEY=not-needed
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:14b

# --- Timeouts and concurrency (optional) ---
# LLM_CONNECT_TIMEOUT=15
# LLM_READ_TIMEOUT=180
# LLM_MAX_RETRIES=2
# LLM_CONCURRENCY=3

# --- Legacy Zhipu env vars still work as fallbacks ---
# ZHIPU_API_KEY, ZHIPU_BASE_URL, ZHIPU_MODEL, etc.
